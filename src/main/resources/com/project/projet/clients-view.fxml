<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="com.project.projet.controller.ClientController" spacing="16" styleClass="content">
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="Gestion des clients" styleClass="section-title" />
        <TextField fx:id="searchField" promptText="Rechercher..." />
    </HBox>

    <GridPane hgap="10" vgap="10" styleClass="card">
        <padding>
            <Insets top="12" right="12" bottom="12" left="12"/>
        </padding>
        <Label text="Nom" GridPane.rowIndex="0" GridPane.columnIndex="0" />
        <TextField fx:id="nomField" GridPane.rowIndex="0" GridPane.columnIndex="1" />
        <Label text="Prenom" GridPane.rowIndex="0" GridPane.columnIndex="2" />
        <TextField fx:id="prenomField" GridPane.rowIndex="0" GridPane.columnIndex="3" />

        <Label text="CIN" GridPane.rowIndex="1" GridPane.columnIndex="0" />
        <TextField fx:id="cinField" GridPane.rowIndex="1" GridPane.columnIndex="1" />
        <Label text="Email" GridPane.rowIndex="1" GridPane.columnIndex="2" />
        <TextField fx:id="emailField" GridPane.rowIndex="1" GridPane.columnIndex="3" />

        <Label text="Telephone" GridPane.rowIndex="2" GridPane.columnIndex="0" />
        <TextField fx:id="telephoneField" GridPane.rowIndex="2" GridPane.columnIndex="1" />
        <Label text="Adresse" GridPane.rowIndex="2" GridPane.columnIndex="2" />
        <TextField fx:id="adresseField" GridPane.rowIndex="2" GridPane.columnIndex="3" />

        <Label text="Permis" GridPane.rowIndex="3" GridPane.columnIndex="0" />
        <TextField fx:id="permisField" GridPane.rowIndex="3" GridPane.columnIndex="1" />
        <Label text="Expiration" GridPane.rowIndex="3" GridPane.columnIndex="2" />
        <DatePicker fx:id="expirationPicker" GridPane.rowIndex="3" GridPane.columnIndex="3" />

        <HBox spacing="8" GridPane.rowIndex="4" GridPane.columnIndex="0" GridPane.columnSpan="4">
            <Button text="Ajouter" onAction="#onAdd" styleClass="primary" />
            <Button text="Modifier" onAction="#onUpdate" />
            <Button text="Supprimer" onAction="#onDelete" />
            <Button text="Reinitialiser" onAction="#onReset" />
        </HBox>
    </GridPane>

    <TableView fx:id="tableView" prefHeight="280">
        <columns>
            <TableColumn fx:id="nomCol" text="Nom" />
            <TableColumn fx:id="prenomCol" text="Prenom" />
            <TableColumn fx:id="cinCol" text="CIN" />
            <TableColumn fx:id="emailCol" text="Email" />
            <TableColumn fx:id="telephoneCol" text="Telephone" />
            <TableColumn fx:id="permisCol" text="Permis" />
            <TableColumn fx:id="expirationCol" text="Expiration" />
        </columns>
    </TableView>
</VBox>
