<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="com.project.projet.controller.MainController" styleClass="app-shell">
    <top>
        <HBox spacing="10" alignment="CENTER_LEFT" styleClass="top-bar">
            <padding>
                <Insets top="12" right="18" bottom="12" left="18"/>
            </padding>
            <Label text="Location de voitures" styleClass="title" />
            <Label fx:id="userLabel" styleClass="muted" />
        </HBox>
    </top>
    <left>
        <VBox spacing="8" styleClass="sidebar">
            <padding>
                <Insets top="16" right="12" bottom="16" left="12"/>
            </padding>
            <Button fx:id="vehiclesButton" text="Vehicules" onAction="#showVehicles" />
            <Button fx:id="clientsButton" text="Clients" onAction="#showClients" />
            <Button fx:id="reservationsButton" text="Reservations" onAction="#showReservations" />
            <Button fx:id="paymentsButton" text="Paiements" onAction="#showPayments" />
            <Button fx:id="returnsButton" text="Retours" onAction="#showReturns" />
            <Button fx:id="statsButton" text="Statistiques" onAction="#showStats" />
        </VBox>
    </left>
    <center>
        <StackPane fx:id="contentPane" padding="16" />
    </center>
</BorderPane>
