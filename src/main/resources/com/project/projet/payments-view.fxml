<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="com.project.projet.controller.PaiementController" spacing="16" styleClass="content">
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="Gestion des paiements" styleClass="section-title" />
    </HBox>

    <GridPane hgap="10" vgap="10" styleClass="card">
        <padding>
            <Insets top="12" right="12" bottom="12" left="12"/>
        </padding>
        <Label text="Reservation" GridPane.rowIndex="0" GridPane.columnIndex="0" />
        <ComboBox fx:id="reservationCombo" GridPane.rowIndex="0" GridPane.columnIndex="1" />
        <Label text="Total" GridPane.rowIndex="0" GridPane.columnIndex="2" />
        <TextField fx:id="totalField" editable="false" GridPane.rowIndex="0" GridPane.columnIndex="3" />

        <Label text="Montant paye" GridPane.rowIndex="1" GridPane.columnIndex="0" />
        <TextField fx:id="paidField" GridPane.rowIndex="1" GridPane.columnIndex="1" />
        <Label text="Reste" GridPane.rowIndex="1" GridPane.columnIndex="2" />
        <Label fx:id="remainingLabel" text="0.00" GridPane.rowIndex="1" GridPane.columnIndex="3" />

        <Label text="Mode" GridPane.rowIndex="2" GridPane.columnIndex="0" />
        <ComboBox fx:id="modeCombo" GridPane.rowIndex="2" GridPane.columnIndex="1" />
        <Label text="Statut" GridPane.rowIndex="2" GridPane.columnIndex="2" />
        <Label fx:id="statusLabel" text="-" GridPane.rowIndex="2" GridPane.columnIndex="3" />

        <HBox spacing="8" GridPane.rowIndex="3" GridPane.columnIndex="0" GridPane.columnSpan="4">
            <Button text="Enregistrer" onAction="#onSave" styleClass="primary" />
        </HBox>
    </GridPane>

    <TableView fx:id="tableView" prefHeight="260">
        <columns>
            <TableColumn fx:id="reservationCol" text="Reservation" />
            <TableColumn fx:id="totalCol" text="Total" />
            <TableColumn fx:id="paidCol" text="Paye" />
            <TableColumn fx:id="remainingCol" text="Reste" />
            <TableColumn fx:id="modeCol" text="Mode" />
            <TableColumn fx:id="statusCol" text="Statut" />
        </columns>
    </TableView>
</VBox>
