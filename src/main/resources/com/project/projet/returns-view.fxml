<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="com.project.projet.controller.RetourController" spacing="16" styleClass="content">
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="Gestion des retours" styleClass="section-title" />
    </HBox>

    <GridPane hgap="10" vgap="10" styleClass="card">
        <padding>
            <Insets top="12" right="12" bottom="12" left="12"/>
        </padding>
        <Label text="Reservation" GridPane.rowIndex="0" GridPane.columnIndex="0" />
        <ComboBox fx:id="reservationCombo" GridPane.rowIndex="0" GridPane.columnIndex="1" />
        <Label text="Date retour" GridPane.rowIndex="0" GridPane.columnIndex="2" />
        <DatePicker fx:id="dateRetourPicker" GridPane.rowIndex="0" GridPane.columnIndex="3" />

        <Label text="Etat" GridPane.rowIndex="1" GridPane.columnIndex="0" />
        <ComboBox fx:id="etatCombo" GridPane.rowIndex="1" GridPane.columnIndex="1" />
        <Label text="Frais" GridPane.rowIndex="1" GridPane.columnIndex="2" />
        <TextField fx:id="fraisField" GridPane.rowIndex="1" GridPane.columnIndex="3" />

        <Label text="Remarque" GridPane.rowIndex="2" GridPane.columnIndex="0" />
        <TextArea fx:id="remarqueArea" GridPane.rowIndex="2" GridPane.columnIndex="1" GridPane.columnSpan="3" prefRowCount="2" />

        <HBox spacing="8" GridPane.rowIndex="3" GridPane.columnIndex="0" GridPane.columnSpan="4">
            <Button text="Enregistrer" onAction="#onSave" styleClass="primary" />
        </HBox>
    </GridPane>

    <TableView fx:id="tableView" prefHeight="260">
        <columns>
            <TableColumn fx:id="reservationCol" text="Reservation" />
            <TableColumn fx:id="dateCol" text="Date retour" />
            <TableColumn fx:id="etatCol" text="Etat" />
            <TableColumn fx:id="fraisCol" text="Frais" />
        </columns>
    </TableView>
</VBox>
