<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="com.project.projet.controller.VehiculeController" spacing="16" styleClass="content">
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="Gestion des vehicules" styleClass="section-title" />
        <TextField fx:id="searchField" promptText="Rechercher..." />
        <ComboBox fx:id="filterStatutCombo" promptText="Statut" />
    </HBox>

    <GridPane hgap="10" vgap="10" styleClass="card">
        <padding>
            <Insets top="12" right="12" bottom="12" left="12"/>
        </padding>
        <Label text="Marque" GridPane.rowIndex="0" GridPane.columnIndex="0" />
        <TextField fx:id="marqueField" GridPane.rowIndex="0" GridPane.columnIndex="1" />
        <Label text="Modele" GridPane.rowIndex="0" GridPane.columnIndex="2" />
        <TextField fx:id="modeleField" GridPane.rowIndex="0" GridPane.columnIndex="3" />

        <Label text="Immatriculation" GridPane.rowIndex="1" GridPane.columnIndex="0" />
        <TextField fx:id="immatriculationField" GridPane.rowIndex="1" GridPane.columnIndex="1" />
        <Label text="Categorie" GridPane.rowIndex="1" GridPane.columnIndex="2" />
        <ComboBox fx:id="categorieCombo" GridPane.rowIndex="1" GridPane.columnIndex="3" />

        <Label text="Carburant" GridPane.rowIndex="2" GridPane.columnIndex="0" />
        <ComboBox fx:id="carburantCombo" GridPane.rowIndex="2" GridPane.columnIndex="1" />
        <Label text="Boite" GridPane.rowIndex="2" GridPane.columnIndex="2" />
        <ComboBox fx:id="boiteCombo" GridPane.rowIndex="2" GridPane.columnIndex="3" />

        <Label text="Places" GridPane.rowIndex="3" GridPane.columnIndex="0" />
        <TextField fx:id="placesField" GridPane.rowIndex="3" GridPane.columnIndex="1" />
        <Label text="Prix/jour" GridPane.rowIndex="3" GridPane.columnIndex="2" />
        <TextField fx:id="prixField" GridPane.rowIndex="3" GridPane.columnIndex="3" />

        <Label text="Statut" GridPane.rowIndex="4" GridPane.columnIndex="0" />
        <ComboBox fx:id="statutCombo" GridPane.rowIndex="4" GridPane.columnIndex="1" />

        <HBox spacing="8" GridPane.rowIndex="5" GridPane.columnIndex="0" GridPane.columnSpan="4">
            <Button text="Ajouter" onAction="#onAdd" styleClass="primary" />
            <Button text="Modifier" onAction="#onUpdate" />
            <Button text="Supprimer" onAction="#onDelete" />
            <Button text="Reinitialiser" onAction="#onReset" />
        </HBox>
    </GridPane>

    <TableView fx:id="tableView" prefHeight="280">
        <columns>
            <TableColumn fx:id="marqueCol" text="Marque" />
            <TableColumn fx:id="modeleCol" text="Modele" />
            <TableColumn fx:id="immatCol" text="Immatriculation" />
            <TableColumn fx:id="categorieCol" text="Categorie" />
            <TableColumn fx:id="carburantCol" text="Carburant" />
            <TableColumn fx:id="boiteCol" text="Boite" />
            <TableColumn fx:id="placesCol" text="Places" />
            <TableColumn fx:id="prixCol" text="Prix/jour" />
            <TableColumn fx:id="statutCol" text="Statut" />
        </columns>
    </TableView>
</VBox>
